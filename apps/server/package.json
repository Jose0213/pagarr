{
  "name": "@pagarr/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Pagarr server -- TypeScript port of Readarr's NzbDrone.Core backend.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-migrations.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.7"
  }
}
