{
  "name": "@pagarr/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Pagarr server -- TypeScript port of Readarr's NzbDrone.Core backend.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-migrations.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check:regex": "node scripts/check-regex-compat.mjs"
  },
  "devDependencies": {
    "@types/adm-zip": "0.5.7",
    "@types/bencode": "4.0.0",
    "@types/express": "^4.17.25",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "8.0.1",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "3.2.7",
    "supertest": "^7.2.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.7"
  },
  "dependencies": {
    "adm-zip": "0.6.0",
    "bencode": "4.0.1",
    "express": "^4.22.2",
    "fast-xml-parser": "5.10.1",
    "node-taglib-sharp": "6.0.3",
    "nodemailer": "9.0.3",
    "sharp": "0.35.3",
    "ws": "^8.21.1"
  }
}
